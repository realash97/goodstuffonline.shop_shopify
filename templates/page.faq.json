          "type": "collapsible_row",
          "settings": {
            "heading": "3. How long does delivery take?",
            "icon": "truck",
            "row_content": "<p>Delivery times depend on your location and the shipping method selected:<\/p><ul><li><strong>Standard Shipping 🚚<\/strong>: 5-7 business days.<\/li><li><strong>Express Shipping ⚡<\/strong>: 2-4 business days.<\/li><\/ul>",
            "page": ""
          }
        },
        "template--18327068148007__37e8cdd4-ab58-48f7-b736-913308245cdb-167980065688e3e5f3-3": {
          "type": "collapsible_row",
          "settings": {
            "heading": "4. Can I track my order?",
            "icon": "chat_bubble",
            "row_content": "<p>Yes! Once your order is shipped, we’ll email you a tracking number so you can monitor your package. 📦<\/p>",
            "page": ""
          }
        },
